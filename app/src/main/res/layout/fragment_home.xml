<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_toolbar"
            android:orientation="vertical"
            android:padding="@dimen/space_xl"
            android:paddingBottom="@dimen/space_xxl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_date_placeholder"
                    android:textColor="@color/toolbar_title"
                    style="@style/TextAppearance.App.Body" />

                <!-- Tema Switcher -->
                <FrameLayout
                    android:id="@+id/layoutThemeToggle"
                    android:layout_width="70dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_toggle_night">

                    <TextView
                        android:id="@+id/tvMoon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙"
                        android:textSize="12sp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="6dp"/>

                    <View
                        android:id="@+id/viewCircle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_toggle_circle"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="3dp"/>

                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <!-- İnsülin Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                style="@style/Widget.App.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/space_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_insulin_tracking"
                            style="@style/TextAppearance.App.SectionTitle" />

                        <TextView
                            android:id="@+id/tvInsulinStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_insulin_status_placeholder"
                            style="@style/TextAppearance.App.Body" />
                    </LinearLayout>

                    <!-- Sabah / Öğle / Akşam -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.App.Card.Subtle">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🌅"
                                    android:textSize="20sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/time_morning"
                                    android:layout_marginTop="2dp"
                                    style="@style/TextAppearance.App.Caption" />
                                <TextView
                                    android:id="@+id/ivMorningCheck"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_done"
                                    android:textSize="16sp"
                                    android:textColor="@color/insulin_done"
                                    android:layout_marginTop="2dp"
                                    android:visibility="gone" />
                                <TextView
                                    android:id="@+id/tvMorningPending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_pending"
                                    android:textSize="16sp"
                                    android:textColor="@color/insulin_pending"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            style="@style/Widget.App.Card.Subtle">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="☀️"
                                    android:textSize="20sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/time_noon"
                                    style="@style/TextAppearance.App.Caption"
                                    android:layout_marginTop="2dp" />
                                <TextView
                                    android:id="@+id/ivNoonCheck"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_done"
                                    android:textSize="16sp"
                                    android:textColor="@color/insulin_done"
                                    android:layout_marginTop="2dp"
                                    android:visibility="gone" />
                                <TextView
                                    android:id="@+id/tvNoonPending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_pending"
                                    android:textSize="16sp"
                                    android:textColor="@color/insulin_pending"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.App.Card.Subtle">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🌙"
                                    android:textSize="20sp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/time_evening"
                                    style="@style/TextAppearance.App.Caption"
                                    android:layout_marginTop="2dp" />
                                <TextView
                                    android:id="@+id/ivEveningCheck"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_done"
                                    android:textSize="16sp"
                                    android:textColor="@color/insulin_done"
                                    android:layout_marginTop="2dp"
                                    android:visibility="gone" />
                                <TextView
                                    android:id="@+id/tvEveningPending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/status_pending"
                                    android:textSize="16sp"
                                    android:textColor="@color/insulin_pending"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Kan Şekeri Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                style="@style/Widget.App.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_last_glucose"
                        android:layout_marginBottom="@dimen/space_sm"
                        style="@style/TextAppearance.App.SectionTitle" />

                    <TextView
                        android:id="@+id/tvLastGlucose"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_no_measurement_today"
                        style="@style/TextAppearance.App.Body" />

                    <TextView
                        android:id="@+id/tvGlucoseWarning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Haftalık Özet Kartı -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                style="@style/Widget.App.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_weekly_summary"
                        android:layout_marginBottom="@dimen/space_md"
                        style="@style/TextAppearance.App.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_measurement"
                                style="@style/TextAppearance.App.Caption" />

                            <TextView
                                android:id="@+id/tvWeeklyCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_zero"
                                style="@style/TextAppearance.App.Metric" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_average"
                                style="@style/TextAppearance.App.Caption" />

                            <TextView
                                android:id="@+id/tvWeeklyAverage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                style="@style/TextAppearance.App.Metric" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_min_max"
                                style="@style/TextAppearance.App.Caption" />

                            <TextView
                                android:id="@+id/tvWeeklyMinMax"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                style="@style/TextAppearance.App.Body" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hızlı Ekle Butonları -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddGlucose"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_primary"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/home_add_measurement"
                    app:icon="@drawable/ic_glucose"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="@android:color/white"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeStepGranularity="1sp"
                    style="@style/Widget.App.Button.Primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddInsulin"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_primary"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_sm"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/home_add_injection"
                    app:icon="@drawable/ic_insulin"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="?attr/colorPrimary"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeStepGranularity="1sp"
                    style="@style/Widget.App.Button.Outlined" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>