<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget"
    android:orientation="vertical"
    android:padding="@dimen/space_md">

    <TextView
        android:id="@+id/tvWidgetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_recent_measurements"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/space_sm"/>

    <LinearLayout
        android:id="@+id/layoutRecord1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/space_xs">
        <TextView android:id="@+id/tvVal1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/white" android:textStyle="bold" android:text="@string/placeholder_double_dash"/>
        <TextView android:id="@+id/tvDate1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/widget_subtle_text" android:textSize="11sp" android:text="@string/placeholder_double_dash"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRecord2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/space_xs">
        <TextView android:id="@+id/tvVal2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/white" android:textStyle="bold" android:text="@string/placeholder_double_dash"/>
        <TextView android:id="@+id/tvDate2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/widget_subtle_text" android:textSize="11sp" android:text="@string/placeholder_double_dash"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRecord3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/space_xs">
        <TextView android:id="@+id/tvVal3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/white" android:textStyle="bold" android:text="@string/placeholder_double_dash"/>
        <TextView android:id="@+id/tvDate3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/widget_subtle_text" android:textSize="11sp" android:text="@string/placeholder_double_dash"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRecord4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/space_xs"
        android:visibility="gone">
        <TextView android:id="@+id/tvVal4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/white" android:textStyle="bold" android:text="@string/placeholder_double_dash"/>
        <TextView android:id="@+id/tvDate4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/widget_subtle_text" android:textSize="11sp" android:text="@string/placeholder_double_dash"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRecord5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">
        <TextView android:id="@+id/tvVal5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/white" android:textStyle="bold" android:text="@string/placeholder_double_dash"/>
        <TextView android:id="@+id/tvDate5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/widget_subtle_text" android:textSize="11sp" android:text="@string/placeholder_double_dash"/>
    </LinearLayout>

</LinearLayout>